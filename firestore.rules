rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: dreams
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable) - The UID of the user who created this dream.
    //   - prompt: string (required, immutable) - The original dream description.
    //   - story: string (required, immutable) - The expanded story generated by AI.
    //   - createdAt: timestamp (required, immutable) - The time the dream was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidDream(data) {
      return hasOnlyAllowedFields(['userId', 'prompt', 'story', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.prompt is string && data.prompt.size() > 0 && data.prompt.size() < 5000 &&
             data.story is string && data.story.size() > 0 && data.story.size() < 20000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /dreams/{dreamId} {
      // Users can only read their own dreams
      allow read: if isDocOwner();
      
      // Users can create dreams if they are authenticated, the data is valid, and they are setting themselves as the owner
      allow create: if isAuthenticated() && isValidDream(request.resource.data);
      
      // Dreams are immutable in this app, so no updates allowed
      allow update: if false;
      
      // Users can delete their own dreams
      allow delete: if isDocOwner();
    }
  }
}
